# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==========================================
# SECURITY: Environment Variables - CRITICAL
# ==========================================
# NEVER commit these files - they contain sensitive data
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# Keep only .env.example for documentation
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ==========================================
# ADDITIONAL SECURITY & CLEANUP
# ==========================================

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS files
Thumbs.db
desktop.ini

# Backup and temporary files
*.backup
*.bak
*.old
*.tmp
*~
.cache

# Logs
logs/
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Output of 'npm pack'
*.tgz

# Temporary folders
tmp/
temp/
